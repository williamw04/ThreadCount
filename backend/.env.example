# Supabase
# Find these in Supabase Dashboard > Settings > API
SUPABASE_URL=
# IMPORTANT: Backend needs the SECRET key (service_role) to bypass RLS
SUPABASE_SECRET_KEY=

# fal.ai
# Get from: https://fal.ai/dashboard/keys
FAL_API_KEY=""

# Google Gemini (optional)
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=""

# CORS - frontend origins allowed to call this backend
# Comma-separated list, e.g., "http://localhost:3000,https://your-app.vercel.app"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
