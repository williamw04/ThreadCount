# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.

# ─── Supabase ───
# Option A: Local Supabase (run `supabase start`, values printed in terminal)
# Option B: Deployed Supabase (find in dashboard: Settings > API)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# ─── Google OAuth (only needed for local Supabase) ───
# The deployed instance stores this in the Supabase dashboard instead.
# Get from: https://console.cloud.google.com/apis/credentials
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=""

# ─── FastAPI Backend ───
VITE_API_BASE_URL="http://localhost:8000"

# ─── fal.ai ───
# NOTE: fal.ai API calls go through backend. DO NOT put API key here.
# Client-side keys are visible in browser dev tools.
